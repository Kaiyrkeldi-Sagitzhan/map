# JWT
JWT_SECRET=123

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://your-domain.com/auth/google/callback
# Optional comma-separated allowlist for multiple frontend callback URLs
# Example: https://your-cloudflare-domain/auth/google/callback,http://localhost:8080/auth/google/callback,http://localhost:5173/auth/google/callback
GOOGLE_ALLOWED_REDIRECT_URLS=

# SMTP for email verification (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
